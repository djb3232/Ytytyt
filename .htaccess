# .htaccess file for Multi-Format Downloader web application

# Enable RewriteEngine
RewriteEngine On

# If using FastCGI
<IfModule mod_fcgid.c>
    AddHandler fcgid-script .fcgi
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ app.fcgi/$1 [QSA,L]
</IfModule>

# If using mod_wsgi
<IfModule mod_wsgi.c>
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ wsgi.py/$1 [QSA,L]
</IfModule>

# Set default index file
DirectoryIndex index.html index.php web_downloader.py

# Protect sensitive files
<FilesMatch "^(\.htaccess|\.git|.*\.py[co]|.*\.sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow access to the web application
<FilesMatch "^(web_downloader\.py|app\.fcgi|wsgi\.py|passenger_wsgi\.py)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# PHP settings (if your host uses PHP)
<IfModule mod_php7.c>
    php_flag display_errors Off
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 1 day"
</IfModule>